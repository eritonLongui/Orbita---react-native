{
  "expo": {
    "name": "Orbita",
    "slug": "Orbita",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon_temp.png",
    "userInterfaceStyle": "dark",
    "scheme": "orbita",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.orbita.fiap",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/icon_temp.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.orbita.fiap",
      "googleServicesFile": "./google-services.json",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-audio",
        {
          "microphonePermission": "A Lyra utiliza seu microfone para conversas e check-ins."
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.649295071611-7nfpj2sibkpa14bm60gkt5l8p5keli8i"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O Orbita usa suas fotos para conversar com a Lyra."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2482b9e2-bd6b-4ace-9083-205051c6bbd7"
      }
    },
    "owner": "marcomendessv"
  }
}
